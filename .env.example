API_KEY=
REPO_PATH=E:\path\to\your\git-repository
# 如果运行环境找不到 git，可填写 Git 可执行文件绝对路径
# GIT_EXECUTABLE=C:\Program Files\Git\cmd\git.exe
MODEL=gpt-4.1
# 评估最近多少次提交；例如 NUM=100 表示分析最近 100 次提交
NUM=30
# 旧配置名仍兼容：COMMIT_LIMIT=30
# 模型请求失败时最多重试次数；默认 3 次
MAX_RETRIES=3
# 重试初始等待秒数，后续按递增间隔等待；默认 2 秒
RETRY_DELAY_SECONDS=2
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# SINCE=2026-07-01
# UNTIL=2026-07-17
# BASE_COMMIT=
# HEAD_COMMIT=
OUTPUT_PATH=git-agent-report.md
# 飞书机器人通知（可选）：启用后，每次分析完成会发送报告摘要
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=
